# ---- Server ----
PORT=5000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/andijon_polka

# ---- Auth ----
TOKEN_KEY=change_this_secret
HASHNUMBER=10

# Default admin (created on first run if no admin exists)
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin123

# Public base URL for serving photos (used by frontends): {host}/api/cdn
IMAGE_ADDRESS=http://localhost:5000/api/cdn

# ---- Passport lookup ----
# Keep PASSPORT_MOCK=true until the real APIs are provided.
PASSPORT_MOCK=true
# Participants younger than this age use the minor (under-18) API.
MINOR_AGE=18

# Adult API (JSHSHIR + birth date)
ADULT_API_URL=
ADULT_API_TOKEN=

# Minor API (under 18)
MINOR_API_URL=
MINOR_API_TOKEN=
