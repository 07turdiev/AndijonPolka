# ---- Server ----
PORT=5000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/andijon_polka

# ---- Auth ----
TOKEN_KEY=change_this_secret
HASHNUMBER=10

# Default admin (created on first run if no admin exists)
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin123

# Public base URL for serving photos (used by frontends): {host}/api/cdn
IMAGE_ADDRESS=http://localhost:5000/api/cdn

# ---- Passport lookup (itg.madaniyat.uz, single API by document type) ----
# true = test data (no real API calls); false = call the real API
PASSPORT_MOCK=true
# Used only to show the "under 18" tag (age < MINOR_AGE).
MINOR_AGE=18

PASSPORT_API_URL=https://itg.madaniyat.uz/api/web/MV/PersonGetByPassportData
# API login + password (Basic header is built automatically)
PASSPORT_API_LOGIN=
PASSPORT_API_PASSWORD=
# OR provide a ready Basic header directly instead of login/password:
# PASSPORT_API_AUTH=Basic xxxxx
